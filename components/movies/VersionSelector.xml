<?xml version="1.0" encoding="utf-8"?>
<component name="VersionSelector" extends="Group">
    <children>
        <Rectangle width="1920" height="1080" color="#000000" opacity="0.75" />
        <Group translation="[100,100]">
            <Poster width="1720" height="880" uri="pkg:/images/dialog.9.png" />
            <LayoutGroup horizAlignment="center" translation="[860,50]" itemSpacings="[40]" layoutDirection="vert">
                <Text text="Select Version" font="font:LargeBoldSystemFont" color="#FFFFFF" horizAlign="center" />
                <MarkupList id="versionMenu" itemComponentName="GelatoVersionItem"
                    itemSize="[1500, 120]" itemSpacing="[0, 12]" numRows="5"
                    vertFocusAnimationStyle="floatingFocus" drawFocusFeedback="false" />
            </LayoutGroup>
        </Group>
    </children>
    <interface>
        <field id="videoTracks" type="array" onChange="videoTracksSet" />
        <field id="videoStreamId" type="string" />
        <field id="codec" type="string" />
    </interface>
</component>